# =============================================================================
# Dependencies
# =============================================================================
node_modules/

# =============================================================================
# Terraform
# =============================================================================
# Local state and provider cache — never commit
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files that may contain secrets — use TF Cloud sensitive variables
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files (local dev overrides — not for VCS)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# OS / editor artefacts
# =============================================================================
.DS_Store
Thumbs.db
